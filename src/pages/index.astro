---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => Number(b.data.pubDate) - Number(a.data.pubDate)
);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section>
				<h1>Hi, I’m Vinayak.</h1>
				<p>
					I publish practical insights on backend architecture, cloud-native systems, and the real-world
					applications of generative AI. This personal blog is a space for technical notes, architecture
					patterns, and lessons learned from building scalable software.
				</p>
			</section>

			<section>
				<h2>What you’ll find here</h2>
				<ul>
					<li><strong>Backend systems:</strong> scalable APIs, event-driven design, and resilient infrastructure.</li>
					<li><strong>Cloud engineering:</strong> AWS serverless patterns, deployment strategy, and operational best practices.</li>
					<li><strong>Generative AI:</strong> prompt engineering, RAG pipelines, and AI-first product ideas.</li>
				</ul>
			</section>

			<section>
				<h2>Latest posts</h2>
				{posts.length > 0 ? (
					<ul>
						{posts.map((post) => (
							<li>
								<a href={`/blog/${post.id}`}>
									<strong>{post.data.title}</strong>
								</a>
								<p>{post.data.description}</p>
							</li>
						))}
					</ul>
				) : (
					<p>No posts are published yet. Check back soon for new articles.</p>
				)}
			</section>

			<section>
				<h2>Want to connect?</h2>
				<p>
					Explore the blog, read the about page, or reach out via the links in the header.
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>
