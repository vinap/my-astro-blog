---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

const today = new Date();

const posts = (await getCollection('blog'))
	.filter((post) => post.data.pubDate <= today)
	.sort(
	(a, b) => Number(b.data.pubDate) - Number(a.data.pubDate)
);
const seriesName = 'Adding intelligence to microservices';
const seriesPosts = posts.filter((p) => p.data.series === seriesName).sort((a, b) => Number(a.data.pubDate) - Number(b.data.pubDate));
const basePath = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section>
				<h1>Hi, I’m Vinayak.</h1>
				<p>
					I write about procurement and sourcing systems, enterprise software delivery, and the real-world
					use of AI in complex business workflows. This blog is where I share lessons from P2P platforms,
					supply chain operations, backend engineering, and building smarter software from real project
					experience.
				</p>
			</section>

			<section>
				<h2>What you’ll find here</h2>
				<ul>
					<li><strong>Procurement and sourcing:</strong> real-world lessons from P2P platforms, supplier workflows, master data, and enterprise buying operations.</li>
					<li><strong>Technical engineering:</strong> backend systems, cloud architecture, integrations, deployment, and software design from real delivery experience.</li>
					<li><strong>Agentic AI:</strong> practical ideas for LLMs, RAG, and intelligent automation in both enterprise software and supply chain products.</li>
				</ul>
			</section>

			<section>
				{seriesPosts.length > 0 ? (
					<>
						<h2>Series: {seriesName}</h2>
						<ul>
							{seriesPosts.map((post) => (
								<li>
									<a href={`${basePath}/blog/${post.id}`}><strong>{post.data.title}</strong></a>
									<p>{post.data.description}</p>
								</li>
							))}
						</ul>
					</>
				) : null}

				<h2>Latest posts</h2>
				{posts.length > 0 ? (
					<ul>
						{posts.map((post) => (
							<li>
								<a href={`${basePath}/blog/${post.id}`}>
									<strong>{post.data.title}</strong>
								</a>
								<p>{post.data.description}</p>
							</li>
						))}
					</ul>
				) : (
					<p>No posts are published yet. Check back soon for new articles.</p>
				)}
			</section>

			<section>
				<h2>Want to connect?</h2>
				<p>
					Explore the blog, read the about page, or reach out via the links in the header.
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>
